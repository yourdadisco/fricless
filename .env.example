# ============================================================
# Fricless — 飞书 AI 机器人网关 配置
# ============================================================

# ── 飞书应用凭证（必填） ────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic Claude API（必填） ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # 可选：代理地址

# ── 网络搜索 ────────────────────────────────────────────────
# SERPAPI_API_KEY=   # 可选：开通后可获得更稳定的搜索能力

# ── 会话存储 ────────────────────────────────────────────────
# SESSION_STORE=memory    # memory | sqlite（默认 memory）
# SQLITE_PATH=./data/sessions.db

# ── 速率限制 ────────────────────────────────────────────────
# RATE_LIMIT_RPM=30        # 每分钟最大请求数
# RATE_LIMIT_BURST=10      # 突发请求数

# ── 上下文管理 ──────────────────────────────────────────────
# MAX_CONTEXT_TOKENS=64000  # 最大上下文 Token 数
# MAX_TOKENS=4096           # 每次输出最大 Token 数

# ── Web 管理面板 ────────────────────────────────────────────
# WEB_PANEL_ENABLED=false
# WEB_PANEL_PORT=18790

# ── Remote Bridge ───────────────────────────────────────────
# BRIDGE_ENABLED=false
# BRIDGE_PORT=18791

# ── 通用 ────────────────────────────────────────────────────
GATEWAY_PORT=18789
LOG_LEVEL=info
